@model PestControlWebApp.Models.PestRecord

@{
    ViewData["Title"] = "Search Pest Record";
}

<h2>Search Pest Record</h2>
<hr/>

<form method="get">
    <div class="mb-3">
        <label>Enter ID to Search</label>
        <input type="number" name="id" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Search</button>
</form>

@if (Model != null)
{
    <hr/>
    <h4>Record Found:</h4>
    <table class="table">
        <tr><th>ID</th><td>@Model.Id</td></tr>
        <tr><th>Pest Type</th><td>@Model.PestType</td></tr>
        <tr><th>Location</th><td>@Model.Location</td></tr>
        <tr><th>Severity</th><td>@Model.Severity</td></tr>
        <tr><th>Status</th><td>@Model.Status</td></tr>
        <tr><th>Technician</th><td>@Model.TechnicianName</td></tr>
        <tr><th>Treatment</th><td>@Model.TreatmentApplied</td></tr>
        <tr><th>Date</th><td>@Model.DateReported.ToShortDateString()</td></tr>
    </table>
    <a href="/Pest/Delete/@Model.Id" class="btn btn-danger">Delete Record</a>
}
else if (Context.Request.Query.ContainsKey("id"))
{
    <p class="text-danger">No record found with that ID.</p>
}
